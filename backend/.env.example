# SECURITY WARNING: Generate a unique secret key for production!
# Use: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=cr6#niublj&qvek53ji=fx9y*n#dofy^bp(e2+eyx8jo6&#b$4

# Debug mode - NEVER set to True in production
DEBUG=False

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Environment name (development, staging, production)
ENVIRONMENT=staging


# DATABASE CONFIGURATION

# Database engine (default: django.db.backends.mysql)
# Options: django.db.backends.postgresql, django.db.backends.mysql, django.db.backends.sqlite3
DB_ENGINE=django.db.backends.mysql

# Database credentials
DB_NAME=task_manager_db
DB_USER=root
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=3306

# Database connection settings
DB_CONN_MAX_AGE=600
DB_ATOMIC_REQUESTS=True
DB_CONNECT_TIMEOUT=10
DB_READ_TIMEOUT=30
DB_WRITE_TIMEOUT=30


# AUTHENTICATION & SECURITY

# Password validation
PASSWORD_MIN_LENGTH=8

# JWT Token Settings
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=your-jwt-secret-key-here

# Security settings (for production)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Cookie settings
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax


# CORS CONFIGURATION

# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True

# Comma-separated list of trusted origins for CSRF
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173


# STATIC & MEDIA FILES

STATIC_URL=/static/
STATIC_ROOT=staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=media

# Maximum file upload size in bytes (default: 5MB)
MAX_UPLOAD_SIZE=5242880


# REDIS CONFIGURATION

# Enable Redis for caching and sessions
USE_REDIS=True

# Redis connection settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# Redis cache settings
REDIS_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
REDIS_MAX_CONNECTIONS=50
REDIS_KEY_PREFIX=taskmanager
CACHE_TIMEOUT=300

# Defender Redis DB (for brute force protection)
DEFENDER_REDIS_DB=0


# DJANGO REST FRAMEWORK

# Pagination
DRF_PAGE_SIZE=20

# Throttling rates
DRF_USER_THROTTLE_RATE=1000/hour
DRF_ANON_THROTTLE_RATE=100/hour


# API DOCUMENTATION

API_TITLE=Task Manager API
API_DESCRIPTION=API documentation for Task Manager application
API_VERSION=1.0.0


# RATE LIMITING & SECURITY

# Rate limiting
RATELIMIT_ENABLE=True

# Django Defender (brute force protection)
DEFENDER_FAILURE_LIMIT=5
DEFENDER_COOLOFF_TIME=300
DEFENDER_ATTEMPT_EXPIRATION=24


# LOGGING CONFIGURATION

# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL_CONSOLE=INFO
LOG_LEVEL_FILE=INFO
LOG_LEVEL_SECURITY=WARNING
LOG_LEVEL_USER_ACTIVITY=INFO
LOG_LEVEL_DJANGO=INFO
LOG_LEVEL_REQUEST=ERROR
LOG_LEVEL_USERS=INFO
LOG_LEVEL_DEFENDER=WARNING
LOG_LEVEL_ROOT=INFO

# Log file settings
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5


# APPLICATION SETTINGS

SITE_NAME=Task Manager
FRONTEND_URL=http://localhost:5173


# INTERNATIONALIZATION

LANGUAGE_CODE=en-us
TIME_ZONE=UTC


# ERROR MONITORING (SENTRY)

# Leave empty to disable Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
RELEASE_VERSION=1.0.0


# ADMIN CONFIGURATION

ADMIN_EMAIL=jamespmurithi@gmail.com

# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
ENVIRONMENT=production

# Database Configuration (MySQL)
DB_ENGINE=django.db.backends.mysql
DB_NAME=task_manager_db
DB_USER=root
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=3306
DB_CONN_MAX_AGE=600
DB_CONNECT_TIMEOUT=10

# Security Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
SECURE_SSL_REDIRECT=True
PASSWORD_MIN_LENGTH=8

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Redis Configuration
USE_REDIS=True
REDIS_HOST=localhost
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/1
REDIS_CONNECT_TIMEOUT=5
REDIS_TIMEOUT=5
REDIS_MAX_CONNECTIONS=50
REDIS_KEY_PREFIX=taskmanager
CACHE_TIMEOUT=300

# Django Defender (Brute Force Protection)
DEFENDER_FAILURE_LIMIT=5
DEFENDER_COOLOFF_TIME=300
DEFENDER_ATTEMPT_EXPIRATION=24

# Sentry Configuration (Optional - for error monitoring)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
RELEASE_VERSION=1.0.0

# Admin Configuration
ADMIN_EMAIL=admin@taskmanager.com

# Application Settings
SITE_NAME=Task Manager
FRONTEND_URL=http://localhost:3000

# File Upload Settings
MAX_UPLOAD_SIZE=5242880
